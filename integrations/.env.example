# Supersonik GTM — environment variables (v1)
# Copy this file to `.env` (git-ignored) and fill in real values.

# ----- Email sequencing (Instantly.ai) -----
# Required for: campaign push, status polling, reply detection
INSTANTLY_API_KEY=

# ----- People + company data (Crustdata) -----
# Required for: contact/company enrichment, signal pulls
CRUSTDATA_API_KEY=

# ----- Local database -----
# Path to the SQLite DB file (default location). Override if needed.
GTM_DB_PATH=./db/gtm.db
